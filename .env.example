# ─── Samarkand Mosaic — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values. Never commit .env.
# App runs in localStorage-only mode if either value is missing.
# Use the PUBLIC anon key — never the service_role key.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
