{
  "name": "samarkand-mosaic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "optimize-assets": "node scripts/optimize-assets.mjs",
    "validate-levels": "node scripts/validate-levels.mjs",
    "build:prod": "npm run validate-levels && npm run optimize-assets && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "pixi.js": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
